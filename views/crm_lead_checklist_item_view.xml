<odoo>
    <record id="crm_checklist_item_view_tree" model="ir.ui.view">
        <field name="name">crm.checklist.item.view.tree</field>
        <field name="model">crm.checklist.item</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>
    
    <record id="action_crm_checklist_item" model="ir.actions.act_window">
        <field name="name">Checklist Items</field>
        <field name="res_model">crm.checklist.item</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem
        id="menu_crm_checklist_item"
        name="Checklist Items"
        parent="crm.crm_menu_config"
        action="action_crm_checklist_item"
    />
</odoo>