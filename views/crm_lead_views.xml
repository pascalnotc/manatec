<odoo>
    <record id="crm_lead_view_form_checklist" model="ir.ui.view">
        <field name="name">crm.lead.view.form.checklist</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Checklist">
                        <field 
                            name="checklist_progress"
                            widget="progressbar"
                            nolabel="1"
                            readonly="1"
                        />
                        <field name="checklist_line_ids">
                            <tree editable="bottom" create="0">
                                <field name="name" readonly="1"/>
                                <field name="done" save_record="1"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
        </field>
    </record>


    <record id="crm_lead_kanban_view_checklist" model="ir.ui.view">
        <field name="name">crm.lead.kanban.view.checklist</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="inside">
                <field name="checklist_progress"/>
            </xpath>

            <xpath expr="//div[hasclass('oe_kanban_footer')]" position="inside">
                <div class="px-2 pb-2">
                    <field name="checklist_progress"
                        widget="progressbar"
                        nolabel="1"
                        readonly="1"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>